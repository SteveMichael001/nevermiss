          <div class="rb"><div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="font-size:12px;color:rgba(255,255,255,.45)">5 customers</span><span style="font-size:12px;font-weight:700;color:var(--g)">$1,125/mo</span></div><div class="bar-track"><div class="bar-fill" data-w="5"></div></div></div>
