<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>NeverMiss AI — Pitch Deck</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;background:#000;color:#fff;font-family:'Plus Jakarta Sans',sans-serif}
:root{--g:#22C55E;--gd:rgba(34,197,94,0.3);--r:#EF4444}
#deck{position:relative;width:100vw;height:100vh;overflow:hidden}
#slides{display:flex;width:1000vw;height:100vh;will-change:transform}
.slide{width:100vw;height:100vh;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(34,197,94,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(34,197,94,0.04) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:1}
.scan{position:absolute;width:100%;height:1px;background:linear-gradient(90deg,transparent,rgba(34,197,94,0.4),transparent);animation:scan 6s linear infinite;pointer-events:none;z-index:2}
@keyframes scan{0%{top:0;opacity:0}5%{opacity:.8}95%{opacity:.2}100%{top:100%;opacity:0}}
.glow{color:var(--g);text-shadow:0 0 20px var(--g),0 0 50px rgba(34,197,94,0.3)}
.holo{background:linear-gradient(135deg,#22C55E,#4ADE80,#86EFAC,#22C55E);background-size:300% 300%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:holoshift 3s ease infinite}
@keyframes holoshift{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes orbpulse{0%,100%{box-shadow:0 0 20px rgba(34,197,94,.5),0 0 50px rgba(34,197,94,.15)}50%{box-shadow:0 0 50px rgba(34,197,94,.9),0 0 100px rgba(34,197,94,.3)}}
@keyframes ringexpand{0%{transform:scale(.5);opacity:.8}100%{transform:scale(2.8);opacity:0}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
#nav{position:fixed;bottom:26px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:9px;z-index:300}
.dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.2);cursor:pointer;transition:all .3s}
.dot.on{background:var(--g);box-shadow:0 0 8px var(--g);width:22px;border-radius:3px}
#bp,#bn{position:fixed;top:50%;transform:translateY(-50%);width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.4);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .3s;z-index:300;font-size:18px;user-select:none}
#bp{left:16px}#bn{right:16px}
#bp:hover,#bn:hover{background:rgba(34,197,94,.1);border-color:var(--g);color:var(--g);box-shadow:0 0 15px rgba(34,197,94,.2)}
#logo{position:fixed;top:20px;left:22px;font-size:13px;font-weight:800;letter-spacing:.12em;color:var(--g);text-shadow:0 0 12px var(--g);z-index:300}
#logo b{color:rgba(255,255,255,.8);font-weight:800}
#ctr{position:fixed;top:20px;right:22px;font-size:11px;font-weight:600;letter-spacing:.25em;color:rgba(255,255,255,.25);z-index:300}
#ctr em{color:var(--g);font-style:normal}
.tag{font-size:10px;letter-spacing:.4em;color:rgba(34,197,94,.7);font-weight:700;margin-bottom:16px}
.sc{background:rgba(255,255,255,.02);border:1px solid rgba(34,197,94,.15);border-radius:6px;padding:26px 30px;position:relative;overflow:hidden}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--g),transparent)}
.bar-track{height:3px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden}
.bar-fill{height:100%;border-radius:2px;width:0%;background:linear-gradient(90deg,var(--g),#4ADE80);box-shadow:0 0 8px rgba(34,197,94,.5);transition:width 1.5s cubic-bezier(.4,0,.2,1)}
.cta-btn{display:inline-block;padding:16px 44px;border:2px solid var(--g);color:var(--g);font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:800;letter-spacing:.15em;text-transform:uppercase;cursor:pointer;background:transparent;position:relative;overflow:hidden;transition:color .3s}
.cta-btn::before{content:'';position:absolute;inset:0;background:var(--g);transform:scaleX(0);transform-origin:left;transition:transform .35s cubic-bezier(.4,0,.2,1);z-index:-1}
.cta-btn:hover{color:#000}.cta-btn:hover::before{transform:scaleX(1)}
.tl-h{flex:1;text-align:center;padding:9px 2px 7px;border-top:2px solid rgba(255,255,255,.06);font-size:8.5px;letter-spacing:.04em;color:rgba(255,255,255,.22)}
.tl-h.peak{border-top-color:var(--r);color:var(--r);text-shadow:0 0 8px rgba(239,68,68,.5);background:rgba(239,68,68,.04)}
.tl-h.on{border-top-color:var(--g);color:rgba(34,197,94,.7)}
@media(max-width:600px){#bp,#bn{display:none}}
</style>
</head>
<body>

<div id="logo">NEVER<b>MISS</b> AI</div>
<div id="ctr"><em id="cnum">01</em> / 10</div>
<div id="deck"><div id="slides">

<!-- S1: HERO -->
<div class="slide" id="s1">
  <div class="grid-bg"></div><div class="scan"></div>
  <canvas id="c1" style="position:absolute;inset:0;width:100%;height:100%;z-index:0"></canvas>
  <div style="position:relative;z-index:10;text-align:center;max-width:960px;padding:0 32px">
    <div class="tag" id="h1a">◆ NEVERMISS AI ◆</div>
    <h1 id="h1b" style="font-size:clamp(2.6rem,7vw,5.5rem);font-weight:900;line-height:1.05;letter-spacing:-.02em">The Silent Killer<br>of Small Businesses.</h1>
    <p id="h1c" style="margin-top:28px;font-size:clamp(.95rem,2.2vw,1.3rem);color:rgba(255,255,255,.45);font-weight:300;max-width:560px;margin-left:auto;margin-right:auto;line-height:1.75">Every missed call is a customer lost forever.<br>Most owners never even know it happened.</p>
    <div id="h1d" style="margin-top:52px;font-size:11px;letter-spacing:.35em;color:rgba(255,255,255,.18)">PRESS → OR SWIPE TO BEGIN</div>
  </div>
</div>

<!-- S2: WHO -->
<div class="slide" id="s2">
  <div class="grid-bg"></div><div class="scan" style="animation-delay:-2s"></div>
  <div style="position:relative;z-index:10;width:100%;max-width:1080px;padding:0 40px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center">
    <div>
      <div class="tag" id="h2a">◆ WHO WE SERVE ◆</div>
      <h2 id="h2b" style="font-size:clamp(2rem,4.5vw,3.8rem);font-weight:900;line-height:1.05;margin-bottom:26px">Meet Mike<br>the Plumber.</h2>
      <div id="h2c" style="background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:26px;margin-bottom:26px">
        <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
          <div style="width:46px;height:46px;border-radius:50%;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.25);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">🔧</div>
          <div><div style="font-weight:800;font-size:16px">Mike's Plumbing Co.</div><div style="font-size:12px;color:rgba(255,255,255,.4);margin-top:2px">2 trucks · 15 years · Solo operator</div></div>
        </div>
        <div style="height:1px;background:rgba(255,255,255,.05);margin-bottom:14px"></div>
        <div class="ws" style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04)"><span style="font-size:13px;color:rgba(255,255,255,.45)">Calls per day</span><span style="font-weight:700;color:var(--g)">12 – 18</span></div>
        <div class="ws" style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04)"><span style="font-size:13px;color:rgba(255,255,255,.45)">Hours unreachable</span><span style="font-weight:700;color:#fff">6 – 8 hrs/day</span></div>
        <div class="ws" style="display:flex;justify-content:space-between;padding:8px 0"><span style="font-size:13px;color:rgba(255,255,255,.45)">Calls he can answer</span><span style="font-weight:700;color:var(--r)">~40%</span></div>
      </div>
      <p id="h2d" style="font-size:clamp(.95rem,1.8vw,1.2rem);font-style:italic;color:rgba(255,255,255,.55);line-height:1.75">"He built his business by hand.<br>He's losing it <span style="color:var(--r);font-style:normal;font-weight:700">one missed call</span> at a time."</p>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:28px">
      <div id="orb-wrap" style="position:relative;width:180px;height:180px;display:flex;align-items:center;justify-content:center">
        <div class="orb-ring" style="position:absolute;width:180px;height:180px;border-radius:50%;border:1px solid rgba(34,197,94,.2);animation:ringexpand 2.2s ease-out infinite"></div>
        <div class="orb-ring" style="position:absolute;width:180px;height:180px;border-radius:50%;border:1px solid rgba(34,197,94,.15);animation:ringexpand 2.2s ease-out .75s infinite"></div>
        <div class="orb-ring" style="position:absolute;width:180px;height:180px;border-radius:50%;border:1px solid rgba(34,197,94,.1);animation:ringexpand 2.2s ease-out 1.5s infinite"></div>
        <div id="phone-orb" style="width:96px;height:96px;border-radius:50%;background:radial-gradient(circle at 35% 35%,rgba(34,197,94,.35),rgba(34,197,94,.05));border:1px solid rgba(34,197,94,.6);display:flex;align-items:center;justify-content:center;font-size:38px;animation:orbpulse 2s ease-in-out infinite,float 4s ease-in-out infinite">📞</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:11px;letter-spacing:.2em;color:var(--r);font-weight:700">INCOMING CALL</div>
        <div style="font-size:11px;color:rgba(255,255,255,.3);margin-top:3px">Mike can't reach it.</div>
      </div>
      <div id="lost-call" style="opacity:0;text-align:center;padding:18px 28px;border:1px solid rgba(239,68,68,.3);background:rgba(239,68,68,.05);border-radius:6px">
        <div style="font-size:10px;letter-spacing:.2em;color:var(--r);font-weight:700">LEAD LOST TO COMPETITOR</div>
        <div style="font-size:32px;font-weight:900;margin-top:4px;color:var(--r)">$1,200</div>
        <div style="font-size:10px;color:rgba(255,255,255,.3);margin-top:2px">gone. silently.</div>
      </div>
    </div>
  </div>
</div>

<!-- S3: THE NUMBERS -->
<div class="slide" id="s3">
  <div class="grid-bg"></div><div class="scan" style="animation-delay:-4s"></div>
  <canvas id="c3" style="position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none"></canvas>
  <div style="position:relative;z-index:10;width:100%;max-width:880px;padding:0 32px;text-align:center">
    <div class="tag" id="h3a">◆ THE NUMBERS ◆</div>
    <h2 id="h3b" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;margin-bottom:52px">The math is brutal.</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:760px;margin:0 auto">
      <div class="sc n-card" id="n1"><div style="font-size:clamp(2.5rem,5vw,3.8rem);font-weight:900;color:var(--g);line-height:1">1 in 4</div><div style="font-size:13px;color:rgba(255,255,255,.45);margin-top:8px">calls go unanswered</div></div>
      <div class="sc n-card" id="n2"><div style="font-size:clamp(2.5rem,5vw,3.8rem);font-weight:900;color:var(--r);line-height:1">80%</div><div style="font-size:13px;color:rgba(255,255,255,.45);margin-top:8px">hang up on voicemail</div></div>
      <div class="sc n-card" id="n3"><div style="font-size:clamp(2.5rem,5vw,3.8rem);font-weight:900;line-height:1">$1,200</div><div style="font-size:13px;color:rgba(255,255,255,.45);margin-top:8px">average missed call value</div></div>
      <div class="sc n-card" id="n4" style="border-color:rgba(239,68,68,.2)"><div class="holo" style="font-size:clamp(2.5rem,5vw,3.8rem);font-weight:900;line-height:1">$50K/yr</div><div style="font-size:13px;color:rgba(255,255,255,.45);margin-top:8px">disappearing. <span style="color:var(--r)">Silently.</span></div></div>
    </div>
  </div>
</div>

<!-- S4: THE GAP -->
<div class="slide" id="s4">
  <div class="grid-bg"></div><div class="scan" style="animation-delay:-1s"></div>
  <div style="position:relative;z-index:10;width:100%;max-width:1000px;padding:0 40px">
    <div style="text-align:center;margin-bottom:52px">
      <div class="tag" id="h4a">◆ MARKET OPPORTUNITY ◆</div>
      <h2 id="h4b" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900">Nobody owns the gap.</h2>
    </div>
    <div style="display:grid;grid-template-columns:1fr 160px 1fr;gap:0;align-items:center;max-width:860px;margin:0 auto">
      <div id="g-left" style="background:rgba(239,68,68,.04);border:1px solid rgba(239,68,68,.2);border-radius:6px;padding:32px;text-align:center">
        <div style="font-size:10px;letter-spacing:.3em;color:rgba(255,255,255,.35);margin-bottom:12px;font-weight:600">ENTERPRISE AI</div>
        <div style="font-size:clamp(2rem,4vw,3.5rem);font-weight:900;color:var(--r)">$449<span style="font-size:1rem;font-weight:400;opacity:.7">/mo</span></div>
        <div style="margin-top:10px;font-size:13px;color:rgba(255,255,255,.4)">Sameday AI</div>
        <div style="margin-top:6px;font-size:11px;color:rgba(239,68,68,.6)">Priced out of reach</div>
      </div>
      <div id="g-mid" style="text-align:center;padding:0 16px">
        <div style="width:1px;height:60px;background:rgba(255,255,255,.06);margin:0 auto 16px"></div>
        <div style="font-size:10px;letter-spacing:.25em;color:rgba(255,255,255,.25);margin-bottom:10px">THE GAP</div>
        <div class="glow" style="font-size:clamp(2.5rem,5vw,4rem);font-weight:900;line-height:1">$250</div>
        <div style="font-size:11px;color:var(--g);letter-spacing:.15em;margin-top:6px;font-weight:700">UNCONTESTED</div>
        <div style="width:1px;height:60px;background:rgba(255,255,255,.06);margin:16px auto 0"></div>
      </div>
      <div id="g-right" style="background:rgba(255,255,255,.015);border:1px solid rgba(255,255,255,.07);border-radius:6px;padding:32px;text-align:center">
        <div style="font-size:10px;letter-spacing:.3em;color:rgba(255,255,255,.35);margin-bottom:12px;font-weight:600">GENERIC AI</div>
        <div style="font-size:clamp(2rem,4vw,3.5rem);font-weight:900;color:rgba(255,255,255,.35)">$29–49<span style="font-size:1rem;font-weight:400">/mo</span></div>
        <div style="margin-top:10px;font-size:13px;color:rgba(255,255,255,.4)">Chatbot services</div>
        <div style="margin-top:6px;font-size:11px;color:rgba(255,255,255,.25)">Sounds wrong. Feels cheap.</div>
      </div>
    </div>
    <p id="h4c" style="text-align:center;margin-top:44px;font-size:14px;color:rgba(255,255,255,.35);letter-spacing:.04em">
      400,000+ home service businesses. No one is selling to them in person.
    </p>
  </div>
</div>

<!-- S5: WHAT -->
<div class="slide" id="s5">
  <div class="grid-bg"></div><div class="scan" style="animation-delay:-3s"></div>
  <div style="position:relative;z-index:10;width:100%;max-width:960px;padding:0 40px;text-align:center">
    <div class="tag" id="h5a">◆ THE PRODUCT ◆</div>
    <h2 id="h5b" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;margin-bottom:44px">A phone number<br>that never sleeps.</h2>
    <div style="display:flex;align-items:center;justify-content:center;gap:36px;margin-bottom:56px">
      <div id="vm-box" style="text-align:center">
        <div style="width:76px;height:76px;border-radius:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:34px;margin:0 auto 10px">📼</div>
        <div style="font-size:10px;color:rgba(255,255,255,.25);letter-spacing:.12em">VOICEMAIL</div>
      </div>
      <div id="vm-arrow" style="font-size:22px;color:rgba(255,255,255,.15)">→</div>
      <div id="ai-box" style="text-align:center;opacity:0">
        <div id="ai-orb" style="width:76px;height:76px;border-radius:50%;background:radial-gradient(circle at 35% 35%,rgba(34,197,94,.3),rgba(34,197,94,.04));border:1px solid rgba(34,197,94,.5);display:flex;align-items:center;justify-content:center;font-size:34px;margin:0 auto 10px;box-shadow:0 0 30px rgba(34,197,94,.25);animation:orbpulse 2s ease-in-out infinite">🤖</div>
        <div style="font-size:10px;color:var(--g);letter-spacing:.12em;font-weight:700">NEVERMISS AI</div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:680px;margin:0 auto">
      <div class="ws-step" id="st1" style="padding:24px;border:1px solid rgba(34,197,94,.15);border-radius:6px;background:rgba(34,197,94,.02)">
        <div style="font-size:26px;margin-bottom:10px">📞</div>
        <div style="font-size:17px;font-weight:800;color:var(--g);margin-bottom:6px">Answers</div>
        <div style="font-size:12px;color:rgba(255,255,255,.4);line-height:1.5">Every call. Every time. Sounds human.</div>
      </div>
      <div class="ws-step" id="st2" style="padding:24px;border:1px solid rgba(34,197,94,.15);border-radius:6px;background:rgba(34,197,94,.02)">
        <div style="font-size:26px;margin-bottom:10px">📋</div>
        <div style="font-size:17px;font-weight:800;color:var(--g);margin-bottom:6px">Captures</div>
        <div style="font-size:12px;color:rgba(255,255,255,.4);line-height:1.5">Name, number, issue, urgency, callback time.</div>
      </div>
      <div class="ws-step" id="st3" style="padding:24px;border:1px solid rgba(34,197,94,.15);border-radius:6px;background:rgba(34,197,94,.02)">
        <div style="font-size:26px;margin-bottom:10px">💬</div>
        <div style="font-size:17px;font-weight:800;color:var(--g);margin-bottom:6px">Texts in 60s</div>
        <div style="font-size:12px;color:rgba(255,255,255,.4);line-height:1.5">Instant lead summary to Mike's phone.</div>
      </div>
    </div>
  </div>
</div>

<!-- S6: TRUST LAYER -->
<div class="slide" id="s6">
  <div class="grid-bg"></div><div class="scan" style="animation-delay:-5s"></div>
  <canvas id="c6" style="position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;opacity:.35"></canvas>
  <div style="position:relative;z-index:10;text-align:center;max-width:780px;padding:0 40px">
    <div class="tag" id="h6a">◆ THE TRUST LAYER ◆</div>
    <h2 id="h6b" style="font-size:clamp(1.8rem,4vw,3rem);font-weight:900;margin-bottom:28px;line-height:1.1">This isn't a phone product.<br>It's a <span class="glow">trust product.</span></h2>
    <p id="h6c" style="font-size:clamp(.95rem,2vw,1.25rem);color:rgba(255,255,255,.6);line-height:1.8;font-style:italic;margin-bottom:44px">"Mike is handing you his customer relationships.<br>If it sounds wrong — <span style="color:var(--r);font-style:normal;font-weight:700">it's his reputation on the line.</span>"</p>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px" id="tp-wrap">
      <div class="tp" style="padding:20px;border:1px solid rgba(34,197,94,.18);border-radius:6px;background:rgba(34,197,94,.02)"><div style="font-size:22px;margin-bottom:8px">🎯</div><div style="font-size:13px;font-weight:700;margin-bottom:4px">Sounds Human</div><div style="font-size:11px;color:rgba(255,255,255,.4);line-height:1.5">Not robotic. Not cold. A real conversation.</div></div>
      <div class="tp" style="padding:20px;border:1px solid rgba(34,197,94,.18);border-radius:6px;background:rgba(34,197,94,.02)"><div style="font-size:22px;margin-bottom:8px">🔒</div><div style="font-size:13px;font-weight:700;margin-bottom:4px">Brand-Safe</div><div style="font-size:11px;color:rgba(255,255,255,.4);line-height:1.5">Answers as Mike's Plumbing, every time.</div></div>
      <div class="tp" style="padding:20px;border:1px solid rgba(34,197,94,.18);border-radius:6px;background:rgba(34,197,94,.02)"><div style="font-size:22px;margin-bottom:8px">⚡</div><div style="font-size:13px;font-weight:700;margin-bottom:4px">Instant Intel</div><div style="font-size:11px;color:rgba(255,255,255,.4);line-height:1.5">Every detail captured. Nothing lost.</div></div>
    </div>
  </div>
</div>

<!-- S7: WHERE/WHEN -->
<div class="slide" id="s7">
  <div class="grid-bg"></div><div class="scan" style="animation-delay:-3.5s"></div>
