      <div class="bc" style="padding:24px;border:1px solid rgba(34,197,94,.2);border-radius:6px;text-align:center"><div style="font-size:26px;margin-bottom:8px">📱</div><div style="font-size:13px;font-weight:700;margin-bottom:4px">Live Demo</div><div style="font-size:11px;color:rgba(255,255,255,.4);line-height:1.5">Call the AI number. Right there. Instant proof.</div></div>
      <div class="bc" style="padding:24px;border:1px solid rgba(34,197,94,.2);border-radius:6px;text-align:center"><div style="font-size:26px;margin-bottom:8px">⚡</div><div style="font-size:13px;font-weight:700;margin-bottom:4px">Uncontested</div><div style="font-size:11px;color:rgba(255,255,255,.4);line-height:1.5">The $200–300/mo gap nobody owns</div></div>
    </div>
