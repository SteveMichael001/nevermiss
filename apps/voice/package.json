{
  "name": "@nevermiss/voice",
  "version": "1.0.0",
  "private": true,
  "description": "NeverMiss AI — Voice AI server (Twilio + Deepgram + conversation engine)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
