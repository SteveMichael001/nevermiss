    "twilio": "^5.4.5",
    "ws": "^8.18.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.19",
    "@types/ws": "^8.5.14",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
