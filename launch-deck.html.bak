  </div>
</div>

<!-- ══ SLIDE 8: LAUNCH CTA ══ -->
<div class="slide" id="s8">
  <canvas id="c8"></canvas>
  <div style="position:relative;z-index:2;text-align:center">
    <!-- Portal rings -->
    <div id="prings" style="position:absolute;left:50%;top:50%;pointer-events:none;opacity:0">
      <div class="pring" style="width:280px;height:280px;margin-left:-140px;margin-top:-140px"></div>
      <div class="pring" style="width:380px;height:380px;margin-left:-190px;margin-top:-190px;animation-delay:.6s"></div>
      <div class="pring" style="width:500px;height:500px;margin-left:-250px;margin-top:-250px;animation-delay:1.2s"></div>
      <div class="pring" style="width:640px;height:640px;margin-left:-320px;margin-top:-320px;animation-delay:1.8s;border-color:rgba(34,197,94,.18)"></div>
    </div>
    <div id="s8ct" style="opacity:0;position:relative;z-index:3">
      <div style="font-size:.78rem;letter-spacing:.22em;color:rgba(34,197,94,.7);font-weight:800;text-transform:uppercase;margin-bottom:1.5rem">Launch</div>
      <h1 style="font-size:clamp(3rem,10vw,7rem);font-weight:800;line-height:1.05;letter-spacing:-.04em;margin-bottom:1.5rem" class="glowtx">
        Never miss<br>a lead.
      </h1>
      <div style="display:flex;align-items:center;justify-content:center;gap:.85rem;margin-bottom:2.5rem">
        <span style="font-size:clamp(.95rem,2.5vw,1.25rem);color:rgba(255,255,255,.65);font-weight:500">$250/month</span>
        <div style="width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,.25)"></div>
        <span style="font-size:clamp(.95rem,2.5vw,1.25rem);color:rgba(255,255,255,.65);font-weight:500">14-day free trial</span>
      </div>
      <button id="cta-btn">Start Free Trial →</button>
      <div style="display:flex;align-items:center;justify-content:center;gap:.7rem;margin-top:1.5rem">
        <div class="pdot"></div>
        <div style="font-size:.88rem;color:rgba(255,255,255,.45);font-weight:500">Live in 20 minutes.</div>
      </div>
      <div style="margin-top:1.75rem;font-size:.72rem;color:rgba(255,255,255,.18)">No contract · Cancel anytime · Works on any number</div>
    </div>
  </div>
</div>

</div><!-- /#deck -->

<!-- Nav -->
<nav id="nav">
  <button class="nb" id="btnP" onclick="nav(-1)">← PREV</button>
  <div id="dots" style="display:flex;gap:6px;align-items:center"></div>
  <button class="nb p" id="btnN" onclick="nav(1)">NEXT →</button>
</nav>

<script>
gsap.registerPlugin(TextPlugin);

const TOTAL = 8;
let cur = 1, animating = false;
let cleanupFns = {};

// ── Init dots ──
const dotsEl = document.getElementById('dots');
for (let i = 1; i <= TOTAL; i++) {
  const d = document.createElement('div');
  d.className = 'ndot'; d.id = 'dot'+i;
  d.onclick = () => go(i);
  dotsEl.appendChild(d);
}

function updateUI() {
  document.getElementById('prog').style.width = (cur/TOTAL*100)+'%';
  document.getElementById('snum').textContent = (cur<10?'0'+cur:cur)+' / 0'+TOTAL;
  document.getElementById('btnP').style.opacity = cur===1?'0.3':'1';
  document.getElementById('btnN').textContent = cur===TOTAL?'RESTART ↺':'NEXT →';
  for (let i=1; i<=TOTAL; i++) {
    const d = document.getElementById('dot'+i);
    d.classList.toggle('on', i===cur);
  }
}

function nav(dir) {
  const n = cur+dir;
  if (n<1) return;
  if (n>TOTAL) { go(1); return; }
  go(n);
}

function go(n) {
  if (n===cur || animating) return;
  animating = true;
  const from = cur;
  // cleanup previous slide
  if (cleanupFns[from]) { cleanupFns[from](); cleanupFns[from]=null; }
  gsap.to('#s'+from, {opacity:0, duration:.45, ease:'power2.inOut', onComplete:()=>{
    document.getElementById('s'+from).classList.remove('active');
  }});
  cur = n; updateUI();
  const el = document.getElementById('s'+n);
  el.classList.add('active');
  gsap.fromTo('#s'+n, {opacity:0},{opacity:1, duration:.45, delay:.2, ease:'power2.inOut', onComplete:()=>{
    animating = false;
    anim(n);
  }});
}

document.addEventListener('keydown', e=>{
  if (e.key==='ArrowRight'||e.key==='ArrowDown') nav(1);
  if (e.key==='ArrowLeft'||e.key==='ArrowUp') nav(-1);
});

// ── Per-slide animations ──
function anim(n) { [,a1,a2,a3,a4,a5,a6,a7,a8][n](); }

// ─── SLIDE 1: OPENING ───
function a1() {
  const canvas = document.getElementById('c1');
  const ctx = canvas.getContext('2d');
  canvas.width = window.innerWidth; canvas.height = window.innerHeight;
  gsap.set(canvas, {opacity:1});
  gsap.set('#s1m', {opacity:0});
  gsap.set('#s1b', {opacity:0});

  const comet = {x:-120, y: canvas.height*0.38};
  const trail = [];
  let raf;

  gsap.to(comet, {x: canvas.width+200, y: canvas.height*0.18, duration:1.6, ease:'power2.in',
    onUpdate:()=>{
      ctx.clearRect(0,0,canvas.width,canvas.height);
      trail.push({x:comet.x, y:comet.y});
      if (trail.length>45) trail.shift();
      for (let i=0;i<trail.length;i++) {
        const t=trail[i], a=(i/trail.length)*0.8, s=(i/trail.length)*5;
        ctx.beginPath(); ctx.arc(t.x,t.y,s,0,Math.PI*2);
        ctx.fillStyle=`rgba(34,197,94,${a})`; ctx.fill();
      }
      // Head glow
      const g=ctx.createRadialGradient(comet.x,comet.y,0,comet.x,comet.y,16);
      g.addColorStop(0,'rgba(255,255,255,.95)');
      g.addColorStop(0.3,'rgba(34,197,94,.9)');
      g.addColorStop(1,'rgba(34,197,94,0)');
      ctx.beginPath(); ctx.arc(comet.x,comet.y,16,0,Math.PI*2);
      ctx.fillStyle=g; ctx.fill();
    },
    onComplete:()=>{
      gsap.to(canvas, {opacity:0, duration:0.8, delay:0.15});
      gsap.to('#s1m', {opacity:1, duration:1, delay:0.4, ease:'power2.out'});
      gsap.to('#s1b', {opacity:1, duration:1.1, delay:2.5, ease:'power2.out'});
    }
  });

  cleanupFns[1] = ()=>{ ctx.clearRect(0,0,canvas.width,canvas.height); cancelAnimationFrame(raf); };
}

// ─── SLIDE 2: THE PAIN ───
function a2() {
  gsap.set(['#s2lb','#s2L','#s2R','#s2c1','#s2c2','#s2ls'], {opacity:0});
  gsap.set('#s2L', {x:-35}); gsap.set('#s2R', {x:35});
  gsap.to('#s2lb', {opacity:1, duration:.5});
  gsap.to('#s2L', {opacity:1, x:0, duration:.75, delay:.3, ease:'power3.out'});
  gsap.to('#s2R', {opacity:1, x:0, duration:.75, delay:.5, ease:'power3.out'});
  gsap.to('#s2c1', {opacity:1, duration:.5, delay:1.1});
  gsap.to('#s2c2', {opacity:1, duration:.5, delay:1.3});
  gsap.to('#s2ls', {opacity:1, duration:.5, delay:1.5});

  // Phone ring waves
  ['rw1','rw2'].forEach((id,i)=>{
    const el = document.getElementById(id);
    if (!el) return;
    gsap.fromTo(el, {attr:{r:i===0?15:25}, opacity:.6},
      {attr:{r:i===0?38:58}, opacity:0, duration:1.4, repeat:-1, delay:i*0.45, ease:'power1.out'});
  });

  // Particle system
  const canvas = document.getElementById('c2');
  const ctx = canvas.getContext('2d');
  canvas.width=window.innerWidth; canvas.height=window.innerHeight;
  let particles=[], raf2, running=true;

  function spawn(){
    particles.push({
      x:Math.random()*canvas.width, y:Math.random()*canvas.height*.65+canvas.height*.15,
      vx:(Math.random()-.5)*.6, vy:-Math.random()*1.4-.4,
      size:Math.random()*3+1, alpha:Math.random()*.5+.25,
      decay:Math.random()*.007+.004
    });
  }
  function loop(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    if(particles.length<55) spawn();
    particles=particles.filter(p=>p.alpha>0);
    particles.forEach(p=>{
      ctx.beginPath(); ctx.arc(p.x,p.y,p.size,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,80,80,${p.alpha})`; ctx.fill();
      p.x+=p.vx; p.y+=p.vy; p.alpha-=p.decay; p.size*=.99;
    });
    if(running) raf2=requestAnimationFrame(loop);
  }
  loop();
  cleanupFns[2]=()=>{ running=false; cancelAnimationFrame(raf2); ctx.clearRect(0,0,canvas.width,canvas.height); };
}

// ─── SLIDE 3: THE DEMO ───
const msgs = [
  {r:'ai',   t:"Hi, thanks for calling Mike's Plumbing — how can I help?"},
  {r:'caller',t:"My water heater burst, I need someone today"},
  {r:'ai',   t:"I've got you — can I get your name and number?"},
  {r:'caller',t:"Yeah, it's John. 619-555-0199."},
  {r:'ai',   t:"Perfect, Mike will call you right back. ✅"},
];
let s3Timers=[];

function a3() {
  s3Timers.forEach(clearTimeout); s3Timers=[];
  document.getElementById('ca').innerHTML='';
  gsap.set(['#s3ph','#s3tx'], {opacity:0});
  gsap.set('#s3ph', {scale:.88, y:18});
  gsap.set('#s3tx', {x:25});

  // Waveform
  const wf=document.getElementById('wf'); wf.innerHTML='';
  for(let i=0;i<20;i++){
    const b=document.createElement('div'); b.className='wbar'; wf.appendChild(b);
    gsap.to(b,{height:(Math.random()*18+4)+'px', duration:.3+Math.random()*.4, repeat:-1, yoyo:true, ease:'sine.inOut', delay:i*.05});
  }

  gsap.to('#s3ph', {opacity:1, scale:1, y:0, duration:.75, delay:.3, ease:'back.out(1.5)'});
  gsap.to('#s3tx', {opacity:1, x:0, duration:.65, delay:.6, ease:'power3.out'});

  let delay=1.2;
  msgs.forEach((msg,i)=>{
    const td=delay, md=delay+0.75;
    delay=md+0.65;
    const t1=setTimeout(()=>{
      const ca=document.getElementById('ca');
      if(!ca) return;
      const typ=document.createElement('div');
      typ.className='bubble '+msg.r;
      typ.style.cssText='opacity:1;transform:translateY(0)';
      typ.innerHTML='<div style="display:flex;gap:4px;align-items:center;padding:2px 0"><div class="tdot"></div><div class="tdot"></div><div class="tdot"></div></div>';
      ca.appendChild(typ); ca.scrollTop=ca.scrollHeight;
      const t2=setTimeout(()=>{ typ.textContent=msg.t; ca.scrollTop=ca.scrollHeight; }, 700);
      s3Timers.push(t2);
    }, td*1000);
    s3Timers.push(t1);
  });

  const smsT=setTimeout(()=> showSMS(), (delay+0.5)*1000);
  s3Timers.push(smsT);

  cleanupFns[3]=()=>{ s3Timers.forEach(clearTimeout); s3Timers=[]; gsap.to('#sms',{y:-135,opacity:0,duration:.4}); };
}

function showSMS(){
  gsap.fromTo('#sms',{y:-135,opacity:0},{y:20,opacity:1,duration:.6,ease:'back.out(1.2)'});
  setTimeout(()=>gsap.to('#sms',{y:-135,opacity:0,duration:.5,ease:'power2.in'}), 5500);
}

// ─── SLIDE 4: HOW IT WORKS ───
function a4() {
  gsap.set(['#s4lb','#s4ti','#s4s1','#s4a1','#s4s2','#s4a2','#s4s3','#s4bg'], {opacity:0});
  gsap.set(['#s4s1','#s4s2','#s4s3'], {y:28});
  const tl=gsap.timeline();
  tl.to('#s4lb',{opacity:1,duration:.4})
    .to('#s4ti',{opacity:1,duration:.5},.2)
    .to('#s4s1',{opacity:1,y:0,duration:.6,ease:'back.out(1.4)'},.5)
    .to('#s4a1',{opacity:1,duration:.4},.9)
    .to('#s4s2',{opacity:1,y:0,duration:.6,ease:'back.out(1.4)'},1.05)
    .to('#s4a2',{opacity:1,duration:.4},1.5)
    .to('#s4s3',{opacity:1,y:0,duration:.6,ease:'back.out(1.4)'},1.6)
    .to('#s4bg',{opacity:1,duration:.5},2.3);
  // pulse icons
  ['si1','si2','si3'].forEach((id,i)=>{
    gsap.to('#'+id,{boxShadow:'0 0 28px rgba(34,197,94,.55), 0 0 55px rgba(34,197,94,.25)',
      duration:.5, repeat:-1, yoyo:true, delay:2.2+i*.5});
  });
}

// ─── SLIDE 5: THE MARKET ───
function a5() {
  gsap.set(['#s5lb','#s5gw','#s5R'], {opacity:0});
  gsap.set('#s5R', {x:30});
  // Generate dot grid
  const grid=document.getElementById('mdg'); grid.innerHTML='';
  for(let i=0;i<375;i++){
    const d=document.createElement('div');
    d.style.cssText='width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.1);transition:all .5s ease';
    d.id='md'+i; grid.appendChild(d);
  }
  gsap.to('#s5lb',{opacity:1,duration:.5,delay:.2});
  gsap.to('#s5gw',{opacity:1,duration:.6,delay:.4});
  gsap.to('#s5R',{opacity:1,x:0,duration:.7,delay:.6,ease:'power3.out'});
  let lit=0;
  const iv=setInterval(()=>{
    if(lit>=20){clearInterval(iv);return;}
    const idx=Math.floor(Math.random()*375);
    const d=document.getElementById('md'+idx);
    if(d){d.style.background='#22C55E';d.style.boxShadow='0 0 8px rgba(34,197,94,.8)';}
    lit++;
  },180);
  cleanupFns[5]=()=>clearInterval(iv);
}

// ─── SLIDE 6: THE MATH ───
function a6() {
  gsap.set(['#s6lb','#s6ti','#s6su','#s6c1','#s6c2','#s6c3','#s6m1','#s6m2'],{opacity:0});
  gsap.set(['#s6c1','#s6c2','#s6c3'],{y:20});
  document.getElementById('cr1').textContent='$0';
  document.getElementById('cr2').textContent='$0';
  document.getElementById('cr3').textContent='0%';
  const tl=gsap.timeline();
  tl.to('#s6lb',{opacity:1,duration:.4})
    .to('#s6ti',{opacity:1,duration:.5},.2)
    .to('#s6su',{opacity:1,duration:.4},.5)
    .to('#s6c1',{opacity:1,y:0,duration:.6,ease:'back.out(1.4)'},.7)
    .to('#s6c2',{opacity:1,y:0,duration:.6,ease:'back.out(1.4)'},.9)
    .to('#s6c3',{opacity:1,y:0,duration:.6,ease:'back.out(1.4)'},1.1)
    .to('#s6m1',{opacity:1,duration:.5},1.7)
    .to('#s6m2',{opacity:1,duration:.5},2.0);
  setTimeout(()=>{
    counter('cr1',0,250,'$','',900);
    setTimeout(()=>counter('cr2',0,25,'$','',750),350);
    setTimeout(()=>counter('cr3',0,90,'','%',750),700);
  },900);
}

function counter(id,from,to,pre,suf,ms){
  const el=document.getElementById(id), start=performance.now();
  function upd(now){
    const p=Math.min((now-start)/ms,1), e=1-Math.pow(1-p,3);
    el.textContent=pre+Math.round(from+(to-from)*e)+suf;
    if(p<1) requestAnimationFrame(upd);
  }
  requestAnimationFrame(upd);
}

// ─── SLIDE 7: SALES MOTION ───
function a7() {
  gsap.set(['#s7lb','#s7mp','#s7R','#ss1','#ss2','#ss3'],{opacity:0});
  gsap.set('#s7mp',{scale:.95}); gsap.set('#s7R',{x:30});
  gsap.set(['#ss1','#ss2','#ss3'],{x:18});
  // SD map grid
  const g=document.getElementById('sdg'); g.innerHTML='';
  for(let i=0;i<80;i++){
    const n=document.createElement('div');
    n.style.cssText='width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.1);transition:all .4s ease';
    n.id='sdn'+i; g.appendChild(n);
  }
  const tl=gsap.timeline();
  tl.to('#s7lb',{opacity:1,duration:.4})
    .to('#s7mp',{opacity:1,scale:1,duration:.7,ease:'power3.out'},.3)
    .to('#s7R',{opacity:1,x:0,duration:.65,ease:'power3.out'},.5)
    .to('#ss1',{opacity:1,x:0,duration:.5,ease:'power3.out'},.95)
    .to('#ss2',{opacity:1,x:0,duration:.5,ease:'power3.out'},1.25)
    .to('#ss3',{opacity:1,x:0,duration:.5,ease:'power3.out'},1.55);
  let ni=0;
  const iv=setInterval(()=>{
    if(ni>=80){clearInterval(iv);return;}
    const nd=document.getElementById('sdn'+ni);
    if(nd){nd.style.background='#22C55E';nd.style.boxShadow='0 0 10px rgba(34,197,94,.8)';}
    ni++;
  },65);
  cleanupFns[7]=()=>clearInterval(iv);
}

// ─── SLIDE 8: LAUNCH CTA ───
function a8() {
  // Portal canvas background
  const canvas=document.getElementById('c8');
  const ctx=canvas.getContext('2d');
  canvas.width=window.innerWidth; canvas.height=window.innerHeight;
  let raf8, alpha=0, running=true;
  function drawPortal(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    alpha=Math.min(alpha+0.005,.35);
    // Central green nebula
    const cx=canvas.width/2, cy=canvas.height/2;
    const g=ctx.createRadialGradient(cx,cy,0,cx,cy,Math.min(canvas.width,canvas.height)*.45);
    g.addColorStop(0,`rgba(34,197,94,${alpha})`);
    g.addColorStop(0.4,`rgba(34,197,94,${alpha*.3})`);
    g.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=g; ctx.fillRect(0,0,canvas.width,canvas.height);
    if(running) raf8=requestAnimationFrame(drawPortal);
  }
  drawPortal();

  gsap.set(['#prings','#s8ct'],{opacity:0});
  gsap.set('#prings',{scale:.4});
  gsap.to('#prings',{opacity:1,scale:1,duration:1.4,ease:'power3.out'});
  gsap.to('#s8ct',{opacity:1,duration:.85,delay:.6,ease:'back.out(1.2)'});

  cleanupFns[8]=()=>{ running=false; cancelAnimationFrame(raf8); ctx.clearRect(0,0,canvas.width,canvas.height); };
}

// ── BOOT ──
(function init(){
  const s1=document.getElementById('s1');
  s1.classList.add('active');
  gsap.to('#s1',{opacity:1,duration:.6,delay:.2});
  updateUI();
  setTimeout(()=>anim(1),500);
})();

// Resize
window.addEventListener('resize',()=>{
  ['c1','c2','c8'].forEach(id=>{const c=document.getElementById(id);if(c){c.width=window.innerWidth;c.height=window.innerHeight;}});
});
</script>
</body>
</html>
