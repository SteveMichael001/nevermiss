<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>NeverMiss AI — Launch Deck</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/TextPlugin.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;background:#000;color:#fff;font-family:'Plus Jakarta Sans',sans-serif}
#deck{position:relative;width:100%;height:100%}
.slide{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;padding:1.5rem 1.5rem 5rem}
.slide.active{pointer-events:all}
#prog{position:fixed;top:0;left:0;height:2px;background:#22C55E;z-index:200;box-shadow:0 0 12px rgba(34,197,94,0.6);transition:width .45s cubic-bezier(.4,0,.2,1)}
#snum{position:fixed;top:1.2rem;right:1.5rem;font-size:11px;font-weight:700;letter-spacing:.2em;color:rgba(255,255,255,.2);z-index:200}
#nav{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:200;display:flex;align-items:center;gap:1rem}
.nb{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.55);padding:9px 20px;border-radius:100px;cursor:pointer;font-family:inherit;font-size:12px;font-weight:700;letter-spacing:.08em;transition:all .2s;backdrop-filter:blur(10px);white-space:nowrap}
.nb:hover,.nb.p{background:rgba(34,197,94,.12);border-color:rgba(34,197,94,.35);color:#22C55E}
.ndot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.18);cursor:pointer;transition:all .3s}
.ndot.on{background:#22C55E;box-shadow:0 0 8px rgba(34,197,94,.8);transform:scale(1.4)}
.slabel{font-size:10px;font-weight:800;letter-spacing:.22em;text-transform:uppercase;color:rgba(34,197,94,.7);margin-bottom:.85rem}
.glowtx{text-shadow:0 0 30px rgba(34,197,94,.6),0 0 70px rgba(34,197,94,.25)}
.glowbx{box-shadow:0 0 30px rgba(34,197,94,.25),0 0 60px rgba(34,197,94,.1)}
.holo{background:linear-gradient(135deg,rgba(34,197,94,.07) 0%,rgba(0,0,0,0) 60%,rgba(34,197,94,.04) 100%);border:1px solid rgba(34,197,94,.18);border-radius:16px}
.pdot{width:9px;height:9px;border-radius:50%;flex-shrink:0;background:#22C55E;box-shadow:0 0 10px #22C55E;animation:pdp 2s ease-in-out infinite}
@keyframes pdp{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.6);opacity:.5}}
.pring{position:absolute;border-radius:50%;border:1.5px solid rgba(34,197,94,.35);animation:prp 3.5s ease-in-out infinite}
@keyframes prp{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.35}50%{transform:translate(-50%,-50%) scale(1.06);opacity:.75}}
canvas{position:absolute;inset:0;pointer-events:none}
#sms{position:fixed;top:-135px;right:16px;width:min(295px,calc(100vw - 32px));background:rgba(6,6,6,.97);border:1px solid rgba(34,197,94,.4);border-radius:16px;padding:12px 14px;z-index:300;backdrop-filter:blur(16px);box-shadow:0 20px 60px rgba(0,0,0,.9),0 0 30px rgba(34,197,94,.18)}
.phone{width:min(265px,78vw);background:#080808;border-radius:36px;border:1.5px solid rgba(255,255,255,.1);padding:18px 13px 14px;box-shadow:0 40px 80px rgba(0,0,0,.9),0 0 50px rgba(34,197,94,.1)}
.pnotch{width:68px;height:5px;border-radius:3px;background:rgba(255,255,255,.15);margin:0 auto 13px}
.bubble{max-width:88%;padding:8px 12px;border-radius:16px;font-size:12px;line-height:1.45;margin-bottom:6px;opacity:0;transform:translateY(8px)}
.bubble.ai{background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.28);align-self:flex-start;border-bottom-left-radius:3px}
.bubble.caller{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.13);align-self:flex-end;border-bottom-right-radius:3px}
.tdot{width:5px;height:5px;border-radius:50%;background:rgba(34,197,94,.7);animation:tdb 1.1s ease-in-out infinite}
.tdot:nth-child(2){animation-delay:.18s}.tdot:nth-child(3){animation-delay:.36s}
@keyframes tdb{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}
.sicon{width:74px;height:74px;border-radius:50%;margin:0 auto 1.2rem;display:flex;align-items:center;justify-content:center;font-size:1.85rem;background:rgba(34,197,94,.08);border:2px solid rgba(34,197,94,.28)}
.wbar{width:3px;border-radius:2px;background:rgba(34,197,94,.45);height:8px;flex-shrink:0}
#cta-btn{padding:14px 36px;border-radius:100px;font-size:1rem;font-weight:700;font-family:inherit;background:#22C55E;color:#000;border:none;cursor:pointer;letter-spacing:.03em;box-shadow:0 0 40px rgba(34,197,94,.5),0 0 80px rgba(34,197,94,.2);transition:transform .2s,box-shadow .2s}
#cta-btn:hover{transform:scale(1.06);box-shadow:0 0 60px rgba(34,197,94,.6),0 0 120px rgba(34,197,94,.3)}
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:1000;background:repeating-linear-gradient(to bottom,transparent,transparent 3px,rgba(0,0,0,.025) 3px,rgba(0,0,0,.025) 4px)}
@media(max-width:640px){
  .slide{padding:1rem 1rem 4.5rem}
  #nav{gap:.65rem}
  .nb{padding:8px 13px;font-size:11px}
}
</style>
</head>
<body>

<div id="prog"></div>
<div id="snum">01 / 08</div>

<!-- SMS Notification -->
<div id="sms">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
    <div style="width:34px;height:34px;border-radius:50%;background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.35);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0">🔔</div>
    <div>
      <div style="font-size:10px;color:rgba(255,255,255,.3);letter-spacing:.12em;font-weight:700">NEVERMISS AI · NOW</div>
      <div style="font-size:13px;font-weight:800;color:#22C55E">New Lead Captured</div>
    </div>
  </div>
  <div style="font-size:12px;color:rgba(255,255,255,.65);line-height:1.5"><span style="font-weight:700;color:#fff">John D.</span> — Burst water heater — <span style="color:#22C55E;font-weight:800">URGENT</span></div>
  <div style="margin-top:10px;padding-top:10px;border-top:1px solid rgba(255,255,255,.07);font-size:12px;color:#22C55E;font-weight:700;cursor:pointer">📞 Tap to call back →</div>
</div>

<div id="deck">

<!-- ══ SLIDE 1: OPENING ══ -->
<div class="slide" id="s1">
  <canvas id="c1"></canvas>
  <div id="s1t" style="position:relative;z-index:2;text-align:center">
    <div id="s1m" style="font-size:clamp(1.8rem,5.5vw,4rem);font-weight:800;line-height:1.2;letter-spacing:-.025em;opacity:0">
      That was a $2,000 job.<br>
      <span style="color:rgba(255,255,255,.32)">Gone.</span>
    </div>
    <div id="s1b" style="margin-top:3.5rem;opacity:0">
      <div style="font-size:clamp(2.8rem,9vw,6.5rem);font-weight:800;letter-spacing:-.04em;line-height:1" class="glowtx">
        <span style="color:#fff">Never</span><span style="color:#22C55E">Miss</span><span style="color:#fff"> AI</span>
      </div>
      <div style="font-size:clamp(.65rem,1.6vw,.9rem);color:rgba(255,255,255,.3);margin-top:1rem;letter-spacing:.18em;font-weight:600">EVERY CALL ANSWERED · EVERY LEAD CAPTURED</div>
    </div>
  </div>
</div>

<!-- ══ SLIDE 2: THE PAIN ══ -->
<div class="slide" id="s2">
  <canvas id="c2"></canvas>
  <div style="position:relative;z-index:2;width:100%;max-width:1050px">
    <div class="slabel text-center" id="s2lb" style="opacity:0">The Problem</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:clamp(1.5rem,5vw,4rem);align-items:center">
      <!-- Roof illustration -->
      <div id="s2L" style="opacity:0;transform:translateX(-35px)">
        <svg viewBox="0 0 320 295" width="100%" style="max-width:340px;margin:0 auto;display:block" xmlns="http://www.w3.org/2000/svg">
          <defs><radialGradient id="sg" cx="75%" cy="15%" r="40%"><stop offset="0%" stop-color="rgba(255,200,50,.12)"/><stop offset="100%" stop-color="rgba(0,0,0,0)"/></radialGradient></defs>
          <rect width="320" height="295" fill="url(#sg)"/>
          <polygon points="25,165 160,78 295,165" fill="rgba(255,255,255,.04)" stroke="rgba(255,255,255,.18)" stroke-width="1.5"/>
          <rect x="25" y="165" width="270" height="11" fill="rgba(255,255,255,.06)" rx="2"/>
          <line x1="65" y1="165" x2="65" y2="176" stroke="rgba(255,255,255,.08)" stroke-width="1"/>
          <line x1="105" y1="165" x2="105" y2="176" stroke="rgba(255,255,255,.08)" stroke-width="1"/>
          <line x1="145" y1="165" x2="145" y2="176" stroke="rgba(255,255,255,.08)" stroke-width="1"/>
          <line x1="185" y1="165" x2="185" y2="176" stroke="rgba(255,255,255,.08)" stroke-width="1"/>
          <line x1="225" y1="165" x2="225" y2="176" stroke="rgba(255,255,255,.08)" stroke-width="1"/>
          <line x1="265" y1="165" x2="265" y2="176" stroke="rgba(255,255,255,.08)" stroke-width="1"/>
          <!-- Worker -->
          <rect x="146" y="118" width="16" height="28" fill="rgba(255,255,255,.13)" rx="3"/>
          <circle cx="154" cy="110" r="10" fill="rgba(255,255,255,.18)"/>
          <ellipse cx="154" cy="103" rx="13" ry="5.5" fill="rgba(255,165,0,.45)"/>
          <rect x="140" y="102" width="28" height="3.5" fill="rgba(255,165,0,.45)" rx="1.5"/>
          <rect x="144" y="142" width="20" height="4" fill="rgba(255,255,255,.1)" rx="2"/>
          <rect x="162" y="126" width="3" height="14" fill="rgba(255,255,255,.2)" rx="1"/>
          <!-- Dotted line to phone -->
          <line x1="154" y1="148" x2="220" y2="220" stroke="rgba(255,255,255,.07)" stroke-width="1" stroke-dasharray="5,5"/>
          <!-- Phone ringing -->
          <g id="phone-grp" transform="translate(220,228)">
            <rect x="-18" y="-18" width="36" height="36" rx="10" fill="rgba(34,197,94,.08)" stroke="rgba(34,197,94,.35)" stroke-width="1.2"/>
            <text x="0" y="8" text-anchor="middle" font-size="18">📱</text>
            <circle id="rw1" cx="0" cy="0" r="26" fill="none" stroke="rgba(34,197,94,.3)" stroke-width="1.2"/>
            <circle id="rw2" cx="0" cy="0" r="42" fill="none" stroke="rgba(34,197,94,.15)" stroke-width="1"/>
          </g>
          <rect x="170" y="270" width="100" height="22" rx="11" fill="rgba(255,50,50,.1)" stroke="rgba(255,50,50,.3)" stroke-width="1"/>
          <text x="220" y="285" text-anchor="middle" font-size="10" fill="rgba(255,90,90,.85)" font-family="Plus Jakarta Sans,sans-serif" font-weight="700">MISSED CALL</text>
        </svg>
        <div style="text-align:center;font-size:.78rem;color:rgba(255,255,255,.28);margin-top:.3rem">Mike. On the job. Unreachable.</div>
      </div>
      <!-- Stats -->
      <div id="s2R" style="opacity:0;transform:translateX(35px)">
        <div style="margin-bottom:1.75rem">
          <div style="font-size:clamp(3rem,9vw,5.5rem);font-weight:800;color:#22C55E;line-height:1" class="glowtx">1 in 4</div>
          <div style="font-size:clamp(.95rem,2.5vw,1.3rem);color:rgba(255,255,255,.65);font-weight:600;margin-top:.4rem">calls go unanswered.</div>
          <div style="font-size:.83rem;color:rgba(255,255,255,.3);margin-top:.35rem;line-height:1.6">They don't leave voicemails.<br>They call your competitor.</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-bottom:.8rem">
          <div class="holo" id="s2c1" style="padding:1rem;opacity:0">
            <div style="font-size:1.75rem;font-weight:800;color:#fff">$2K</div>
            <div style="font-size:.7rem;color:rgba(255,255,255,.38);margin-top:.2rem">avg job value</div>
          </div>
          <div class="holo" id="s2c2" style="padding:1rem;opacity:0">
            <div style="font-size:1.75rem;font-weight:800;color:rgba(255,90,90,.9)">×4/day</div>
            <div style="font-size:.7rem;color:rgba(255,255,255,.38);margin-top:.2rem">missed calls avg</div>
          </div>
        </div>
        <div id="s2ls" style="padding:1rem 1.2rem;border-radius:13px;background:rgba(255,50,50,.04);border:1px solid rgba(255,50,50,.2);opacity:0">
          <div style="font-size:.67rem;color:rgba(255,80,80,.55);letter-spacing:.13em;font-weight:800;text-transform:uppercase;margin-bottom:.4rem">Monthly Revenue Bleeding Out</div>
          <div style="font-size:2.1rem;font-weight:800;color:rgba(255,80,80,.9)">$16,000+</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══ SLIDE 3: THE DEMO ══ -->
<div class="slide" id="s3">
  <div style="position:relative;z-index:2;width:100%;max-width:950px;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:clamp(1.5rem,5vw,4rem)">
    <!-- Phone mockup -->
    <div id="s3ph" style="opacity:0;transform:scale(.88) translateY(18px);flex-shrink:0">
      <div class="phone glowbx">
        <div class="pnotch"></div>
        <div style="background:linear-gradient(180deg,#0c1015 0%,#000 100%);border-radius:22px;padding:18px 13px 14px">
          <div style="font-size:10px;color:#22C55E;letter-spacing:.15em;font-weight:800;text-align:center;margin-bottom:4px">● LIVE CALL</div>
          <div style="font-size:.88rem;font-weight:800;color:#fff;text-align:center;margin-bottom:2px">Mike's Plumbing</div>
          <div style="font-size:10px;color:rgba(255,255,255,.35);text-align:center;margin-bottom:11px">(619) 555-0142</div>
          <div id="wf" style="display:flex;align-items:center;justify-content:center;gap:3px;height:22px;margin-bottom:13px"></div>
          <div id="ca" style="display:flex;flex-direction:column;min-height:190px;gap:0;overflow:hidden"></div>
        </div>
      </div>
    </div>
    <!-- Text -->
    <div id="s3tx" style="opacity:0;transform:translateX(25px);max-width:380px">
      <div class="slabel">Live Demo</div>
      <h2 style="font-size:clamp(1.6rem,4vw,2.8rem);font-weight:800;line-height:1.2;margin-bottom:.85rem">
        Your AI picks up.<br><span style="color:#22C55E">Every. Single. Time.</span>
      </h2>
      <p style="color:rgba(255,255,255,.42);font-size:.88rem;line-height:1.75;margin-bottom:1.3rem">Sounds human. Captures leads. Texts you in under 60 seconds. No menus. No hold music. No lost jobs.</p>
      <div style="display:flex;align-items:center;gap:.7rem;padding:.85rem 1.1rem;border-radius:12px;background:rgba(34,197,94,.07);border:1px solid rgba(34,197,94,.22)">
        <div class="pdot"></div>
        <div>
          <div style="font-size:.77rem;font-weight:800;color:#22C55E">AI Active 24/7</div>
          <div style="font-size:.7rem;color:rgba(255,255,255,.35);margin-top:1px">Mike's on a job. AI has the phone.</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══ SLIDE 4: HOW IT WORKS ══ -->
<div class="slide" id="s4">
  <div style="position:relative;z-index:2;width:100%;max-width:900px">
    <div class="slabel text-center" id="s4lb" style="opacity:0">How It Works</div>
    <h2 id="s4ti" style="font-size:clamp(1.7rem,4vw,2.9rem);font-weight:800;text-align:center;margin-bottom:.5rem;opacity:0">
      Zero to answered in <span style="color:#22C55E">under 60 seconds.</span>
    </h2>
    <!-- Steps -->
    <div style="display:flex;gap:1rem;margin-top:2.5rem;align-items:flex-start;justify-content:center;flex-wrap:wrap">
      <div id="s4s1" style="opacity:0;transform:translateY(28px);text-align:center;flex:1;min-width:180px;max-width:240px">
        <div class="sicon" id="si1">📞</div>
        <div style="font-size:.68rem;letter-spacing:.2em;color:rgba(34,197,94,.7);font-weight:800;margin-bottom:.4rem">STEP 01</div>
        <div style="font-size:1rem;font-weight:700;margin-bottom:.45rem">Call Comes In</div>
        <div style="font-size:.82rem;color:rgba(255,255,255,.42);line-height:1.65">Customer calls. You're on the job. NeverMiss AI answers instantly — sounds just like your business.</div>
      </div>
      <!-- Arrow 1 -->
      <div id="s4a1" style="opacity:0;display:flex;align-items:center;padding-top:37px;flex-shrink:0">
        <div style="width:35px;height:2px;background:linear-gradient(90deg,rgba(34,197,94,.5),rgba(34,197,94,.2))"></div>
        <div style="width:0;height:0;border-top:5px solid transparent;border-bottom:5px solid transparent;border-left:8px solid rgba(34,197,94,.4)"></div>
      </div>
      <div id="s4s2" style="opacity:0;transform:translateY(28px);text-align:center;flex:1;min-width:180px;max-width:240px">
        <div class="sicon" id="si2">🤖</div>
        <div style="font-size:.68rem;letter-spacing:.2em;color:rgba(34,197,94,.7);font-weight:800;margin-bottom:.4rem">STEP 02</div>
        <div style="font-size:1rem;font-weight:700;margin-bottom:.45rem">AI Captures Lead</div>
        <div style="font-size:.82rem;color:rgba(255,255,255,.42);line-height:1.65">Conversation feels human. Gets their name, number, and what they need. No menus. Just results.</div>
      </div>
      <!-- Arrow 2 -->
      <div id="s4a2" style="opacity:0;display:flex;align-items:center;padding-top:37px;flex-shrink:0">
        <div style="width:35px;height:2px;background:linear-gradient(90deg,rgba(34,197,94,.5),rgba(34,197,94,.2))"></div>
        <div style="width:0;height:0;border-top:5px solid transparent;border-bottom:5px solid transparent;border-left:8px solid rgba(34,197,94,.4)"></div>
      </div>
      <div id="s4s3" style="opacity:0;transform:translateY(28px);text-align:center;flex:1;min-width:180px;max-width:240px">
        <div class="sicon" id="si3">⚡</div>
        <div style="font-size:.68rem;letter-spacing:.2em;color:rgba(34,197,94,.7);font-weight:800;margin-bottom:.4rem">STEP 03</div>
        <div style="font-size:1rem;font-weight:700;margin-bottom:.45rem">You Get Texted</div>
        <div style="font-size:.82rem;color:rgba(255,255,255,.42);line-height:1.65">Within 60 seconds: who called, why, how urgent. One tap to call back. Job secured.</div>
      </div>
    </div>
    <div id="s4bg" style="text-align:center;margin-top:2.5rem;opacity:0">
      <div style="display:inline-flex;align-items:center;gap:.7rem;padding:.7rem 1.5rem;border-radius:100px;background:rgba(34,197,94,.07);border:1px solid rgba(34,197,94,.28)">
        <div class="pdot"></div>
        <span style="font-size:.82rem;font-weight:700;color:#22C55E">Complete in under 60 seconds — guaranteed</span>
      </div>
    </div>
  </div>
</div>

<!-- ══ SLIDE 5: THE MARKET ══ -->
<div class="slide" id="s5">
  <div style="position:relative;z-index:2;width:100%;max-width:1050px">
    <div class="slabel text-center" id="s5lb" style="opacity:0">The Market</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:clamp(1.5rem,5vw,4rem);align-items:center">
      <!-- Dot grid -->
      <div id="s5gw" style="opacity:0">
        <div style="margin-bottom:.85rem;font-size:.8rem;color:rgba(255,255,255,.35)">400,000+ small contractors · No great solution</div>
        <div id="mdg" style="display:grid;grid-template-columns:repeat(25,1fr);gap:5px;max-width:340px"></div>
        <div style="margin-top:.85rem;display:flex;gap:1.25rem;font-size:.72rem;color:rgba(255,255,255,.38)">
          <div style="display:flex;align-items:center;gap:.4rem"><div style="width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.15)"></div>Untapped</div>
          <div style="display:flex;align-items:center;gap:.4rem"><div style="width:7px;height:7px;border-radius:50%;background:#22C55E;box-shadow:0 0 6px #22C55E"></div>NeverMiss customer</div>
        </div>
      </div>
      <!-- Comparison -->
      <div id="s5R" style="opacity:0;transform:translateX(30px)">
        <h2 style="font-size:clamp(1.7rem,4vw,2.5rem);font-weight:800;line-height:1.2;margin-bottom:1.75rem">
          The gap nobody<br>filled. <span style="color:#22C55E">Until now.</span>
        </h2>
        <div style="display:flex;flex-direction:column;gap:.7rem">
          <div style="padding:.9rem 1.1rem;border-radius:12px;background:rgba(255,50,50,.04);border:1px solid rgba(255,50,50,.15);display:flex;justify-content:space-between;align-items:center">
            <div><div style="font-size:.88rem;font-weight:700;color:rgba(255,255,255,.55)">SameDay AI</div><div style="font-size:.72rem;color:rgba(255,80,80,.65);margin-top:2px">Priced out small contractors</div></div>
            <div style="font-size:1.1rem;font-weight:800;color:rgba(255,80,80,.8)">$449/mo</div>
          </div>
          <div style="padding:.9rem 1.1rem;border-radius:12px;background:rgba(255,50,50,.04);border:1px solid rgba(255,50,50,.15);display:flex;justify-content:space-between;align-items:center">
            <div><div style="font-size:.88rem;font-weight:700;color:rgba(255,255,255,.55)">Generic AI</div><div style="font-size:.72rem;color:rgba(255,80,80,.65);margin-top:2px">Not built for trades. Fails.</div></div>
            <div style="font-size:1.1rem;font-weight:800;color:rgba(255,80,80,.8)">Fails</div>
          </div>
          <div style="padding:.9rem 1.1rem;border-radius:12px;background:rgba(255,50,50,.04);border:1px solid rgba(255,50,50,.15);display:flex;justify-content:space-between;align-items:center">
            <div><div style="font-size:.88rem;font-weight:700;color:rgba(255,255,255,.55)">Answering Service</div><div style="font-size:.72rem;color:rgba(255,80,80,.65);margin-top:2px">Slow, scripted, expensive</div></div>
            <div style="font-size:1.1rem;font-weight:800;color:rgba(255,80,80,.8)">$400+</div>
          </div>
          <div style="padding:.9rem 1.1rem;border-radius:13px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.4);display:flex;justify-content:space-between;align-items:center;box-shadow:0 0 25px rgba(34,197,94,.15)">
            <div>
              <div style="font-size:.88rem;font-weight:800;color:#22C55E">NeverMiss AI</div>
