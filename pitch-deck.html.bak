  <div class="grid-bg"></div><div class="scan" style="animation-delay:-2.5s"></div>
  <div style="position:relative;z-index:10;width:100%;max-width:960px;padding:0 40px">
    <div style="text-align:center;margin-bottom:44px">
      <div class="tag" id="h9a">◆ THE MATH ◆</div>
      <h2 id="h9b" style="font-size:clamp(1.8rem,4vw,3rem);font-weight:900">90% margins.<br>Compounding fast.</h2>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start">
