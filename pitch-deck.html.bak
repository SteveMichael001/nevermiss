          <div class="rb"><div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="font-size:12px;color:rgba(255,255,255,.45)">50 customers</span><span style="font-size:12px;font-weight:700;color:#fff">$11,250/mo</span></div><div class="bar-track"><div class="bar-fill" data-w="50"></div></div></div>
          <div class="rb"><div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="font-size:12px;color:rgba(255,255,255,.45)">100 customers</span><span class="glow" style="font-size:12px;font-weight:700">$22,500/mo</span></div><div class="bar-track"><div class="bar-fill" data-w="100" style="background:linear-gradient(90deg,#22C55E,#4ADE80,#86EFAC)"></div></div></div>
