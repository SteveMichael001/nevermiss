          <div id="sdg" style="display:grid;grid-template-columns:repeat(10,1fr);gap:8px;margin-bottom:.85rem"></div>
          <div style="font-size:.68rem;color:rgba(255,255,255,.2)">← Chula Vista · La Mesa · El Cajon · Santee →</div>
        </div>
      </div>
      <!-- Sales steps -->
      <div id="s7R" style="opacity:0;transform:translateX(30px)">
