        <div style="font-size:10px;letter-spacing:.25em;color:rgba(255,255,255,.35);margin-bottom:14px;font-weight:600">UNIT ECONOMICS</div>
        <div class="mr" id="mr1" style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.05)"><span style="font-size:13px;color:rgba(255,255,255,.45)">Revenue</span><span style="font-size:19px;font-weight:800;color:var(--g)">$250/mo</span></div>
        <div class="mr" id="mr2" style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.05)"><span style="font-size:13px;color:rgba(255,255,255,.45)">COGS (AI infra)</span><span style="font-size:19px;font-weight:700;color:rgba(255,255,255,.5)">~$25/mo</span></div>
        <div class="mr" id="mr3" style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid rgba(34,197,94,.25)"><span style="font-size:13px;color:rgba(255,255,255,.45)">Gross Margin</span><span style="font-size:19px;font-weight:900;color:var(--g)">90%</span></div>
        <div id="mr4" style="padding:18px 0">
