      <div class="wc" style="padding:20px;border:1px solid rgba(239,68,68,.2);background:rgba(239,68,68,.03);border-radius:6px"><div style="font-size:10px;letter-spacing:.2em;color:var(--r);font-weight:700;margin-bottom:8px">SATURDAY AM</div><div style="font-size:14px;font-weight:700;margin-bottom:5px">Mike is off. Phone is on.</div><div style="font-size:12px;color:rgba(255,255,255,.4);line-height:1.5">Neighbors comparing notes. First to answer wins.</div></div>
      <div class="wc" style="padding:20px;border:1px solid rgba(239,68,68,.2);background:rgba(239,68,68,.03);border-radius:6px"><div style="font-size:10px;letter-spacing:.2em;color:var(--r);font-weight:700;margin-bottom:8px">SUNDAY EMERGENCY</div><div style="font-size:14px;font-weight:700;margin-bottom:5px">Competitor's VM picks up.</div><div style="font-size:12px;color:rgba(255,255,255,.4);line-height:1.5">NeverMiss doesn't. The job is yours.</div></div>
    </div>
  </div>
</div>

